// Prisma schema for the Samuel A. Olawale Memorial Foundation
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Donations submitted via the Donate page
model Donation {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  amount      Float
  currency    String   @default("USD")
  method      String   // card | mobile_money | bank_transfer
  frequency   String   @default("one_time") // one_time | monthly | annual
  program     String?  // which program the donation is earmarked for
  message     String?
  status      String   @default("pending") // pending | completed | failed
  createdAt   DateTime @default(now())
}

// Volunteer registrations via the Volunteer page
model Volunteer {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String
  location    String?
  occupation  String?
  skills      String   // comma-separated
  interests   String   // comma-separated
  availability String?
  message     String?
  status      String   @default("pending") // pending | approved | active | declined
  createdAt   DateTime @default(now())
}

// Contact form submissions
model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("new") // new | read | replied | archived
  createdAt DateTime @default(now())
}

// Newsletter subscribers
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String   @default("footer")
  createdAt DateTime @default(now())
}

// Foundation events (managed via Admin)
model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String   // memorial_lecture | fundraiser | remembrance | workshop | community
  description String
  location    String
  startDate   DateTime
  endDate     DateTime?
  image       String?
  capacity    Int?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// News articles & publications
model NewsArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String   // news | press_release | annual_report | publication
  excerpt     String
  body        String
  author      String?
  image       String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

// Testimonials
model Testimonial {
  id        String   @id @default(cuid())
  author    String
  role      String
  body      String
  avatar    String?
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Gallery items (photo, video, audio, documentary)
model GalleryItem {
  id          String   @id @default(cuid())
  title       String
  type        String   // photo | video | audio | documentary
  url         String
  thumbnail   String?
  description String?
  year        Int?
  createdAt   DateTime @default(now())
}
