# Database (SQLite file path — must be writable by the web server)
# On Webuzo, use an ABSOLUTE path.
DATABASE_URL=file:/home/USERNAME/public_html/rasmuta/db/custom.db

# Optional: set Node environment
NODE_ENV=production

# Optional: change the port the Next.js standalone server listens on.
# Webuzo's Node.js App feature will usually set PORT for you via Passenger,
# but if you are running the standalone server manually behind a reverse proxy,
# uncomment and set this:
# PORT=3000
